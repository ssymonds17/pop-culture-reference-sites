{
  "name": "film-api",
  "version": "0.1.0",
  "bin": {
    "film-api": "bin/film-api.js"
  },
  "scripts": {
    "build:all": "npm run build:create-film && npm run build:get-films && npm run build:get-film-by-id && npm run build:update-film && npm run build:delete-film && npm run build:get-genres && npm run build:get-random-films && npm run build:get-director-by-person-id && npm run build:get-directors && npm run build:update-director-stats && npm run build:get-stats && npm run build:get-years && npm run build:get-year && npm run build:update-year-stats && npm run build:search && npm run build:search-tmdb && npm run build:get-tmdb-film-details && npm run build:import-films",
    "build:create-film": "esbuild lambda/create-film.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/create-film/index.js",
    "build:get-films": "esbuild lambda/get-films.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-films/index.js",
    "build:get-film-by-id": "esbuild lambda/get-film-by-id.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-film-by-id/index.js",
    "build:update-film": "esbuild lambda/update-film.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-film/index.js",
    "build:delete-film": "esbuild lambda/delete-film.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/delete-film/index.js",
    "build:get-genres": "esbuild lambda/get-genres.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-genres/index.js",
    "build:get-random-films": "esbuild lambda/get-random-films.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-random-films/index.js",
    "build:get-director-by-person-id": "esbuild lambda/get-director-by-person-id.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-director-by-person-id/index.js",
    "build:get-directors": "esbuild lambda/get-directors.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-directors/index.js",
    "build:update-director-stats": "esbuild lambda/update-director-stats.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-director-stats/index.js",
    "build:get-stats": "esbuild lambda/get-stats.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-stats/index.js",
    "build:get-years": "esbuild lambda/get-years.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-years/index.js",
    "build:get-year": "esbuild lambda/get-year.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-year/index.js",
    "build:update-year-stats": "esbuild lambda/update-year-stats.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/update-year-stats/index.js",
    "build:search": "esbuild lambda/search.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/search/index.js",
    "build:search-tmdb": "esbuild lambda/search-tmdb.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/search-tmdb/index.js",
    "build:get-tmdb-film-details": "esbuild lambda/get-tmdb-film-details.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/get-tmdb-film-details/index.js",
    "build:import-films": "esbuild lambda/import-films.ts --bundle --platform=node --target=node22.11.0 --outfile=build/apps/import-films/index.js",
    "test": "jest",
    "cdk": "npx cdk",
    "synth": "rm -rf ./build/cdk.out && npx cdk synth -q -o ./build/cdk.out",
    "deploy": "npx cdk deploy -a ./build/cdk.out"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/jest": "^29.5.14",
    "@types/mongoose": "^5.11.96",
    "@types/node": "22.7.9",
    "aws-cdk": "^2.1020.2",
    "esbuild": "^0.25.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.17.0",
    "@types/aws-lambda": "^8.10.147",
    "aws-cdk-lib": "^2.180.0",
    "axios": "^1.13.6",
    "constructs": "^10.4.2",
    "mongoose": "^8.16.1"
  }
}
