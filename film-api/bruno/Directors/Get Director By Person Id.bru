meta {
  name: Get Director By Person Id
  type: http
  seq: 2
}

get {
  url: {{API_URL}}/director/{{TMDB_PERSON_ID}}
  body: none
  auth: none
}

docs {
  Retrieves a director by their TMDb person ID.
  The director document is populated with all associated films.

  Set the TMDB_PERSON_ID environment variable to test this endpoint.

  Example TMDb person IDs:
  - 2963 (Nicolas Cage)
  - 1037 (Stanley Kubrick)
  - 5602 (Buster Keaton)
}
