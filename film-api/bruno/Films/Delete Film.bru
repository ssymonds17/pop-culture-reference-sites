meta {
  name: Delete Film
  type: http
  seq: 5
}

delete {
  url: {{API_URL}}/film/{{FILM_ID}}
  body: none
  auth: none
}

docs {
  Deletes a film by its MongoDB ObjectId.

  WARNING: This does NOT cascade to directors or year stats.
  You should manually recalculate stats after deleting films.

  Set the FILM_ID environment variable to test this endpoint.
}
